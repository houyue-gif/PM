generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id      String   @id @default(cuid())
  name    String
  members Member[]
  teams   Team[]
  projects Project[]
}

model Team {
  id          String   @id @default(cuid())
  name        String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  members     TeamMember[]
  projects    Project[]
}

model Member {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  role           String
  workspaceId    String
  workspace      Workspace       @relation(fields: [workspaceId], references: [id])
  teamMembership TeamMember[]
  projectMembers ProjectMember[]
  ownedProjects  Project[]       @relation("ProjectOwner")
  phases         ProjectPhase[]
  milestones     Milestone[]
}


model TeamMember {
  id       String @id @default(cuid())
  teamId   String
  memberId String
  team     Team   @relation(fields: [teamId], references: [id])
  member   Member @relation(fields: [memberId], references: [id])
  @@unique([teamId, memberId])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String
  projects ProjectTag[]
}

model Project {
  id            String          @id @default(cuid())
  code          String          @unique
  name          String
  description   String
  status        String
  phase         String
  type          String
  businessLine  String
  ownerId       String
  owner         Member          @relation("ProjectOwner", fields: [ownerId], references: [id])
  teamId        String
  team          Team            @relation(fields: [teamId], references: [id])
  workspaceId   String
  workspace     Workspace       @relation(fields: [workspaceId], references: [id])
  visibility    String          @default("workspace")
  archived      Boolean         @default(false)
  progress      Int             @default(0)
  scheduleDelta Int             @default(0)
  health        String          @default("good")
  riskLevel     String          @default("low")
  templateId    String?
  template      ProjectTemplate? @relation(fields: [templateId], references: [id])
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  members       ProjectMember[]
  tags          ProjectTag[]
  phases        ProjectPhase[]
  milestones    Milestone[]
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  memberId  String
  role      String  @default("member")
  project   Project @relation(fields: [projectId], references: [id])
  member    Member  @relation(fields: [memberId], references: [id])
  @@unique([projectId, memberId])
}

model ProjectTag {
  id        String  @id @default(cuid())
  projectId String
  tagId     String
  project   Project @relation(fields: [projectId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])
  @@unique([projectId, tagId])
}

model ProjectPhase {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  name      String
  type      String
  ownerId   String
  owner     Member   @relation(fields: [ownerId], references: [id])
  startDate DateTime
  endDate   DateTime
  status    String
  keyNode   Boolean  @default(false)
  note      String?
}

model Milestone {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id])
  name             String
  kind             String
  targetDate       DateTime
  actualDate       DateTime?
  status           String
  ownerId          String
  owner            Member   @relation(fields: [ownerId], references: [id])
  criteria         String
  relatedTaskCount Int      @default(0)
  keyNode          Boolean  @default(false)
  note             String?
}

model ProjectTemplate {
  id                String   @id @default(cuid())
  name              String
  description       String
  projectType       String
  defaultPhaseNames Json
  defaultMilestones Json
  defaultTags       Json
  isSystem          Boolean  @default(false)
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  projects          Project[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  scope     String
  scopeId   String
  actorId   String
  eventType String?
  message   String
  createdAt DateTime @default(now())
}

model Notification {
  id         String   @id @default(cuid())
  memberId   String
  type       String
  title      String
  targetType String
  targetId   String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ConfigOption {
  id       String @id @default(cuid())
  category String
  key      String
  value    String
  @@unique([category, key])
}
