generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id         String      @id @default(cuid())
  name       String
  workspaces Workspace[]
}

model Workspace {
  id             String         @id @default(cuid())
  name           String
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  teams          Team[]
  projects       Project[]
  members        Member[]
}

model Team {
  id          String       @id @default(cuid())
  name        String
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id])
  members     TeamMember[]
}

model Member {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  workspaceId    String
  workspace      Workspace       @relation(fields: [workspaceId], references: [id])
  roleId         String
  role           Role            @relation(fields: [roleId], references: [id])
  teamMembership TeamMember[]
  projectMembers ProjectMember[]
}

model TeamMember {
  id       String @id @default(cuid())
  teamId   String
  memberId String
  team     Team   @relation(fields: [teamId], references: [id])
  member   Member @relation(fields: [memberId], references: [id])
}

model Role {
  id          String       @id @default(cuid())
  name        String
  members     Member[]
  permissions Permission[]
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  description String
  roleId      String
  role        Role   @relation(fields: [roleId], references: [id])
}

model Project {
  id            String          @id @default(cuid())
  code          String          @unique
  name          String
  description   String
  status        String
  phase         String
  type          String
  businessLine  String
  ownerId       String
  teamId        String
  workspaceId   String
  visibility    String          @default("workspace")
  archived      Boolean         @default(false)
  progress      Int             @default(0)
  scheduleDelta Int             @default(0)
  riskLevel     String          @default("low")
  templateId    String?
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  workspace     Workspace       @relation(fields: [workspaceId], references: [id])
  members       ProjectMember[]
  phases        ProjectPhase[]
  milestones    Milestone[]
  tasks         Task[]
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  memberId  String
  role      String  @default("member")
  project   Project @relation(fields: [projectId], references: [id])
  member    Member  @relation(fields: [memberId], references: [id])
}

model ProjectPhase {
  id        String   @id @default(cuid())
  projectId String
  name      String
  type      String
  ownerId   String
  startDate DateTime
  endDate   DateTime
  status    String
  keyNode   Boolean  @default(false)
  note      String?
  project   Project  @relation(fields: [projectId], references: [id])
}

model Milestone {
  id               String   @id @default(cuid())
  projectId        String
  name             String
  kind             String
  targetDate       DateTime
  actualDate       DateTime?
  status           String
  ownerId          String
  criteria         String
  relatedTaskCount Int      @default(0)
  keyNode          Boolean  @default(false)
  note             String?
  project          Project  @relation(fields: [projectId], references: [id])
}

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  projectType String
  isSystem    Boolean  @default(false)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String
  status      String
  priority    String
  dueDate     DateTime?
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id])
  assigneeId  String
  creatorId   String
  watchers    TaskWatcher[]
  comments    Comment[]
  tagId       String?
  tag         Tag?        @relation(fields: [tagId], references: [id])
}

model TaskWatcher {
  id       String @id @default(cuid())
  taskId   String
  memberId String
  task     Task   @relation(fields: [taskId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  memberId  String
  content   String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  scope     String
  scopeId   String
  actorId   String
  message   String
  createdAt DateTime @default(now())
}

model Notification {
  id         String   @id @default(cuid())
  memberId   String
  type       String
  title      String
  targetType String
  targetId   String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Tag {
  id    String @id @default(cuid())
  name  String
  color String
  tasks Task[]
}

model RecentVisit {
  id        String   @id @default(cuid())
  memberId  String
  type      String
  targetId  String
  label     String
  visitedAt DateTime @default(now())
}
